generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  communications Communication[]

  @@map("users")
}

model Template {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  is_active   Boolean           @default(true)
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  versions    TemplateVersion[]

  @@map("templates")
}

model TemplateVersion {
  id                    String          @id @default(uuid())
  template_id           String
  version               Int
  subject               String          @db.VarChar(255)
  body                  String
  body_type             String          @db.VarChar(20)
  variables_schema_json Json?
  is_active             Boolean         @default(true)
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  template              Template        @relation(fields: [template_id], references: [id], onDelete: Cascade)
  communications        Communication[]

  @@unique([template_id, version])
  @@index([template_id])
  @@map("template_versions")
}

model Communication {
  id                      String           @id @default(uuid())
  channel                 String           @db.VarChar(20)
  source_type             String           @db.VarChar(20)
  status                  String           @db.VarChar(30)
  subject                 String?          @db.VarChar(255)
  body                    String?
  body_type               String?          @db.VarChar(20)
  template_version_id     String?
  template_variables_json Json?
  scheduled_at            DateTime?
  processing_at           DateTime?
  sent_at                 DateTime?
  created_by_user_id      String?
  created_at              DateTime         @default(now())
  updated_at              DateTime         @updatedAt

  template_version        TemplateVersion? @relation(fields: [template_version_id], references: [id], onDelete: SetNull)
  user                    User?            @relation(fields: [created_by_user_id], references: [id], onDelete: SetNull)

  attachments             CommunicationAttachment[]
  recipients              CommunicationRecipient[]

  @@map("communications")
}

model CommunicationAttachment {
  id                 String   @id @default(uuid())
  communication_id   String
  original_file_name String   @db.VarChar(255)
  storage_provider   String   @db.VarChar(30)
  storage_key        String   @db.VarChar(500)
  mime_type          String   @db.VarChar(120)
  file_size_bytes    BigInt
  created_at         DateTime @default(now())

  communication Communication @relation(fields: [communication_id], references: [id], onDelete: Cascade)

  @@index([communication_id])
  @@map("communication_attachments")
}

model CommunicationRecipient {
  id               String   @id @default(uuid())
  communication_id String
  recipient_type   String   @db.VarChar(10)
  email            String   @db.VarChar(180)
  created_at       DateTime @default(now())

  communication Communication @relation(fields: [communication_id], references: [id], onDelete: Cascade)

  @@map("communication_recipients")
}
